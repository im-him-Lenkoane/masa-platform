[Unit]
Description=MASA.Health ASP.NET Core Service
After=network.target

[Service]
WorkingDirectory=/var/www/masa/health
ExecStart=/usr/bin/dotnet /var/www/masa/health/MASA.Health.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=masa-health
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
