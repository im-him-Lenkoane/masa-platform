[Unit]
Description=MASA.MINM ASP.NET Core Service
After=network.target

[Service]
WorkingDirectory=/var/www/masa/minm
ExecStart=/usr/bin/dotnet /var/www/masa/minm/MASA.MINM.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=masa-minm
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
