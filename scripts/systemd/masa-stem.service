[Unit]
Description=MASA.STEM ASP.NET Core Service
After=network.target

[Service]
WorkingDirectory=/var/www/masa/stem
ExecStart=/usr/bin/dotnet /var/www/masa/stem/MASA.STEM.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=masa-stem
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
