[Unit]
Description=MASA.BA ASP.NET Core Service
After=network.target

[Service]
WorkingDirectory=/var/www/masa/ba
ExecStart=/usr/bin/dotnet /var/www/masa/ba/MASA.BA.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=masa-ba
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_PRINT_TELEMETRY_MESSAGE=false

[Install]
WantedBy=multi-user.target
