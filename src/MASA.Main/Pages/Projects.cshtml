@page "/projects"
@model ProjectsModel
@{ ViewData["Title"] = "Our Projects"; }
<section class="section" style="padding-top:120px;">
  <div class="container">
    <span class="eyebrow">What We Build</span>
    <h1 style="margin-bottom:2rem;">Our Projects</h1>
    <div class="grid-3">
      <a href="https://edu.masa.org.za"    class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>Education Platform</h3><p>Grade 10-12 and tertiary academic support with AI tutoring.</p></a>
      <a href="https://ba.masa.org.za"     class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>Builders Academy</h3><p>Full LMS for youth skills development and certification.</p></a>
      <a href="https://stem.masa.org.za"   class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>MASA STEM</h3><p>Out-of-classroom STEM learning for youth.</p></a>
      <a href="https://minm.masa.org.za"   class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>Morgan in Maths</h3><p>Mathematics for every grade and level.</p></a>
      <a href="https://iis.masa.org.za"    class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>Injustices in Society</h3><p>Social justice reporting and AI-assisted triage.</p></a>
      <a href="https://health.masa.org.za" class="card" style="display:flex;flex-direction:column;gap:.75rem;"><h3>MASA Health</h3><p>Health support, SRHR, and GBV resources.</p></a>
    </div>
  </div>
</section>
