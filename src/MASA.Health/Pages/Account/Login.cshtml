@page "/login"
@model LoginModel
@{ ViewData["Title"] = "Sign In"; }
<section class="section" style="padding-top:120px;">
  <div class="container-sm" style="max-width:480px;">
    <span class="eyebrow">MASA Health</span>
    <h1 style="margin-bottom:.75rem;">Sign In</h1>
    <p style="margin-bottom:2rem;">Enter your credentials provided by your MASA administrator.</p>
    @if(TempData["Error"] != null){<div class="alert alert-error">@TempData["Error"]</div>}
    <form class="card" method="post">
      <div class="form-group"><label>Email Address</label><input class="form-control" type="email" name="Email" required /></div>
      <div class="form-group"><label>Password</label><input class="form-control" type="password" name="Password" required /></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:.5rem;">Sign In</button>
    </form>
  </div>
</section>
