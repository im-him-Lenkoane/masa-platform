@page
@model IndexModel
@{ ViewData["Title"] = "Home"; }
<section class="hero">
  <div class="hero-bg"></div>
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow anim d1">MASA &middot; IIS</div>
        <h1 class="hero-title anim d2" style="margin-bottom:1rem;">Injustices in Society</h1>
        <p class="hero-sub anim d3">Your voice matters. Report social injustices, GBV, and service delivery failures.</p>
        <div class="hero-actions anim d4">
          <a href="#content" class="btn btn-primary">Get Started</a>
          <a href="/about"   class="btn btn-outline">About</a>
        </div>
      </div>
      <div class="hero-visual anim d3"></div>
    </div>
  </div>
</section>
<section id="content" class="section">
  <div class="container">
    <div class="section-hd">
      <span class="eyebrow">Advocacy</span>
      <h2>Injustices in Society</h2>
      <p>Your voice matters. Report social injustices, GBV, and service delivery failures.</p>
    </div>
    <div class="grid-3">
      <div class="card anim d1" style="aspect-ratio:1.4;background:var(--c-gold-dim);"></div>
      <div class="card anim d2" style="aspect-ratio:1.4;background:var(--c-gold-dim);opacity:.7;"></div>
      <div class="card anim d3" style="aspect-ratio:1.4;background:var(--c-gold-dim);opacity:.5;"></div>
    </div>
  </div>
</section>
